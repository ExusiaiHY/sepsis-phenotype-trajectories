{
  "permissions": {
    "allow": [
      "Bash(pdflatex -interaction=nonstopmode RESEARCH_PAPER.tex)",
      "Bash(python3 -c \":*)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(du *)",
      "Bash(find *)",
      "Bash(wc *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "command": "echo '\\n[HOOK REMINDER] Check: did you commit and push changes? Run git status to verify.'"
      }
    ]
  }
}
